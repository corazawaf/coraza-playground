{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>corazawaf/renovate-config"
  ],
  "constraints": {
    "go": "1.24"
  },
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "enabled": true
    },
    {
      "matchManagers": ["github-actions"],
      "enabled": true
    }
  ]
}
