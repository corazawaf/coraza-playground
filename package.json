{
  "name": "coraza-playground",
  "version": "2.0.0",
  "description": "Coraza WAF Playground with SecLang syntax highlighting",
  "private": true,
  "type": "module",
  "scripts": {
    "build-grammar": "lezer-generator grammar/seclang.grammar -o src/lang/seclang-parser.ts",
    "dev": "npm run build-grammar && vite",
    "build": "npm run build-grammar && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.10.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/common": "^1.2.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/lr": "^1.4.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@lezer/generator": "1.8.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vitest": "3.2.4"
  }
}
